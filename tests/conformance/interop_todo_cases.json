      },
      "expected_decision": true,
      "expected_verdict": "allow"
    },
    {
      "name": "read_todos__beth",
      "rule": "read: any directory user (viewer)",
      "request": {
        "subject": { "type": "user", "id": "beth@the-smiths.com" },
        "action": { "name": "can_read_todos" },
        "resource": { "type": "todo", "id": "todo-1" }
      },
      "expected_decision": true,
      "expected_verdict": "allow"
