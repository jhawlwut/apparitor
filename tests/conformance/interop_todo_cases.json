  "batch": [
    {
      "name": "spec_batch__morty_update_mixed",
      "rule": "canonical interop batch: editor updating another's then own todo; mixed result blocks the plan",
      "request": {
        "subject": { "type": "user", "id": "morty@the-citadel.com" },
        "action": { "name": "can_update_todo" },
        "options": { "evaluations_semantic": "execute_all" },
        "evaluations": [
          {
            "resource": {
              "type": "todo",
              "id": "7240d0db-8ff0-41ec-98b2-34a096273b9f",
              "properties": { "ownerID": "rick@the-citadel.com" }
            }
          },
          {
            "resource": {
              "type": "todo",
              "id": "7240d0db-8ff0-41ec-98b2-34a096273b9e",
              "properties": { "ownerID": "morty@the-citadel.com" }
            }
          }
        ]
      },
      "response": {
        "evaluations": [{ "decision": false }, { "decision": true }]
      },
      "expected_decisions": [false, true],
      "expected_verdict": "block"
    },
    {
      "name": "batch__rick_read_todos_all_allow",
      "rule": "read is universal; an all-allow plan is authorised",
      "request": {
        "subject": { "type": "user", "id": "rick@the-citadel.com" },
        "action": { "name": "can_read_todos" },
        "evaluations": [
          { "resource": { "type": "todo", "id": "todo-1" } },
          { "resource": { "type": "todo", "id": "todo-2" } },
          { "resource": { "type": "todo", "id": "todo-3" } }
        ]
      },
      "response": {
        "evaluations": [{ "decision": true }, { "decision": true }, { "decision": true }]
      },
      "expected_decisions": [true, true, true],
      "expected_verdict": "allow"
    }
